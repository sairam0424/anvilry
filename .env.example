# ─── "Ask my portfolio" chatbot — LLM provider ───────────────────────────────
# Provider for the chatbot. "bedrock" (default) = AWS Bedrock; "anthropic" = direct API.
# Switching providers is an env change, not a code change.
LLM_PROVIDER=bedrock

# ─── AWS Bedrock (used when LLM_PROVIDER=bedrock) ─────────────────────────────
# Anthropic on Bedrock. Models: Opus 4.6 (primary) -> Sonnet 4.6 -> Haiku 4.5 (fallback).
# Credentials are stored BASE64-ENCODED and decoded at runtime (raw keys also work —
# a non-base64 value is passed through unchanged). Use BEDROCK_* (not AWS_*) names so
# the AWS default credential chain never picks up the encoded values by mistake.
BEDROCK_ACCESS_KEY_ID=BASE64_OR_RAW_ACCESS_KEY_ID
BEDROCK_SECRET_ACCESS_KEY=BASE64_OR_RAW_SECRET_ACCESS_KEY
# BEDROCK_SESSION_TOKEN=        # optional, only for temporary STS credentials
# Region: prefer BEDROCK_REGION. AWS_REGION is a RESERVED var on Vercel/Lambda and
# was observed corrupted in production ("s-east-1") — use the BEDROCK_ name to avoid
# the platform mangling it. Code reads BEDROCK_REGION first, then AWS_REGION, then default.
BEDROCK_REGION=us-east-1
AWS_REGION=us-east-1

# ─── Direct Anthropic API (used ONLY when LLM_PROVIDER=anthropic) ─────────────
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Chat rate limiting (Upstash Redis) — OPTIONAL but recommended for prod ───
# Per-IP limit on /api/chat, /api/tts, /api/transcribe (8 req/min) so bots can't run
# up Bedrock/Polly/Transcribe cost. FAILS OPEN: if these are unset, the limiter is a
# no-op and chat still works (fine for local dev). Create a free DB at
# https://console.upstash.com/ and add both values in Vercel Project Settings →
# Environment Variables to activate it.
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ─── Voice (optional) — NO NEW ENV VARS ──────────────────────────────────────
# The voice features are OPT-IN and the free path is 100% browser-native (Web Speech
# API: SpeechRecognition + speechSynthesis) — it needs ZERO configuration here.
#
# Two optional in-app upgrades reuse the EXISTING BEDROCK_* creds above (no new
# vendor, no new env var):
#   • AWS Polly Neural TTS      → /api/tts        (toggle: ⌘K "Use higher-quality voice (Polly)")
#   • AWS Transcribe streaming  → /api/transcribe (toggle: ⌘K "Mic: use private transcription (AWS)")
# To enable them, just grant the Bedrock IAM key two extra actions:
#   polly:SynthesizeSpeech  and  transcribe:StartStreamTranscription   (see DEPLOY.md).
# Both routes FAIL CLOSED — without the IAM permission they return non-2xx and the
# client silently falls back to the free browser voice, so nothing breaks. See VOICE.md.

# ─── Anvil header voice orb (build-time mode) ─────────────────────────────────
# The "Anvil" orb is a small Siri-style button in the site header. On click it opens the
# two-way voice surface. Mode (NEXT_PUBLIC_ is inlined at build time — a re-deploy is
# needed to flip it):
#   inplace (DEFAULT) — Siri-style: the orb expands IN PLACE into a non-modal panel
#                       anchored under it and starts listening (desktop); mobile falls
#                       back to the centered modal (iOS Siri takes over the screen too).
#   modal             — always the centered modal overlay (the prior behavior).
#   off               — hide the orb (ship dark).
# It only renders where the browser supports speech recognition, and never runs WebGL in
# the header (the live 3D orb is inside the open panel only). The dedicated "Voice" view
# is always available regardless of this flag. (Legacy: NEXT_PUBLIC_ENABLE_ANVIL_ORB="false"
# still maps to off.)
# NEXT_PUBLIC_ANVIL_ORB_MODE=inplace

# The "experience" inside the voice surface — how much chrome shows when the orb expands:
#   classic (DEFAULT) — the full in-place panel (orb + captions + prompt chips + controls).
#   core              — the minimal Siri mode: orb-only + a frosted result card, no panel
#                       chrome. Auto-listens on open. Answer-only card, no transcript.
# Orthogonal to ORB_MODE (placement). Default "classic" → unchanged behavior until flipped.
# NEXT_PUBLIC_ANVIL_ORB_EXPERIENCE=classic

# Add the active set to Vercel Project Settings → Environment Variables for production.

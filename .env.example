# ─── "Ask my portfolio" chatbot — LLM provider ───────────────────────────────
# Provider for the chatbot. "bedrock" (default) = AWS Bedrock; "anthropic" = direct API.
# Switching providers is an env change, not a code change.
LLM_PROVIDER=bedrock

# ─── AWS Bedrock (used when LLM_PROVIDER=bedrock) ─────────────────────────────
# Anthropic on Bedrock. Models: Sonnet 4.6 (primary) -> Opus 4.6 -> Haiku 4.5 (fallback).
# Credentials are stored BASE64-ENCODED and decoded at runtime (raw keys also work —
# a non-base64 value is passed through unchanged). Use BEDROCK_* (not AWS_*) names so
# the AWS default credential chain never picks up the encoded values by mistake.
BEDROCK_ACCESS_KEY_ID=BASE64_OR_RAW_ACCESS_KEY_ID
BEDROCK_SECRET_ACCESS_KEY=BASE64_OR_RAW_SECRET_ACCESS_KEY
# BEDROCK_SESSION_TOKEN=        # optional, only for temporary STS credentials
# Region: prefer BEDROCK_REGION. AWS_REGION is a RESERVED var on Vercel/Lambda and
# was observed corrupted in production ("s-east-1") — use the BEDROCK_ name to avoid
# the platform mangling it. Code reads BEDROCK_REGION first, then AWS_REGION, then default.
BEDROCK_REGION=us-east-1
AWS_REGION=us-east-1

# ─── Direct Anthropic API (used ONLY when LLM_PROVIDER=anthropic) ─────────────
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Chat rate limiting (Upstash Redis) — OPTIONAL but recommended for prod ───
# Per-IP limit on /api/chat, /api/tts, /api/transcribe (8 req/min) so bots can't run
# up Bedrock/Polly/Transcribe cost. FAILS OPEN: if these are unset, the limiter is a
# no-op and chat still works (fine for local dev). Create a free DB at
# https://console.upstash.com/ and add both values in Vercel Project Settings →
# Environment Variables to activate it.
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ─── Voice (optional) — NO NEW ENV VARS ──────────────────────────────────────
# The voice features are OPT-IN and the free path is 100% browser-native (Web Speech
# API: SpeechRecognition + speechSynthesis) — it needs ZERO configuration here.
#
# Two optional in-app upgrades reuse the EXISTING BEDROCK_* creds above (no new
# vendor, no new env var):
#   • AWS Polly Neural TTS      → /api/tts        (toggle: ⌘K "Use higher-quality voice (Polly)")
#   • AWS Transcribe streaming  → /api/transcribe (toggle: ⌘K "Mic: use private transcription (AWS)")
# To enable them, just grant the Bedrock IAM key two extra actions:
#   polly:SynthesizeSpeech  and  transcribe:StartStreamTranscription   (see DEPLOY.md).
# Both routes FAIL CLOSED — without the IAM permission they return non-2xx and the
# client silently falls back to the free browser voice, so nothing breaks. See VOICE.md.

# ─── Anvil header voice orb (build-time mode) ─────────────────────────────────
# The "Anvil" orb is a small Siri-style button in the site header. On click it opens the
# two-way voice surface. Mode (NEXT_PUBLIC_ is inlined at build time — a re-deploy is
# needed to flip it):
#   inplace (DEFAULT) — Siri-style: the orb expands IN PLACE into a non-modal panel
#                       anchored under it and starts listening (desktop); mobile falls
#                       back to the centered modal (iOS Siri takes over the screen too).
#   modal             — always the centered modal overlay (the prior behavior).
#   off               — hide the orb (ship dark).
# It only renders where the browser supports speech recognition, and never runs WebGL in
# the header (the live 3D orb is inside the open panel only). The dedicated "Voice" view
# is always available regardless of this flag. (Legacy: NEXT_PUBLIC_ENABLE_ANVIL_ORB="false"
# still maps to off.)
# ─── Enabled Views (build-time) ───────────────────────────────────────────────
# Comma-separated list of views to enable BEYOND Classic (which is always on).
# Options: gamified, chat, developer, voice
# If UNSET (default): ALL views are enabled (current behavior).
# If SET to an empty string: Classic-only (all other views hidden).
# Examples:
#   NEXT_PUBLIC_ENABLED_VIEWS=gamified,chat,developer,voice   (all on, same as default)
#   NEXT_PUBLIC_ENABLED_VIEWS=chat,voice                      (only Chat + Voice)
#   NEXT_PUBLIC_ENABLED_VIEWS=                                (Classic only)
# NEXT_PUBLIC_ENABLED_VIEWS=gamified,chat,developer,voice

# NEXT_PUBLIC_ANVIL_ORB_MODE=inplace

# The "experience" inside the voice surface — how much chrome shows when the orb expands:
#   classic (DEFAULT) — the full in-place panel (orb + captions + prompt chips + controls).
#   core              — the minimal Siri mode: orb-only + a frosted result card, no panel
#                       chrome. Auto-listens on open. Answer-only card, no transcript.
# Orthogonal to ORB_MODE (placement). Default "classic" → unchanged behavior until flipped.
# NEXT_PUBLIC_ANVIL_ORB_EXPERIENCE=classic

# ─── Voice picker UX mode (build-time, v1.7) ──────────────────────────────────
# Which UI shape the voice picker renders:
#   descriptor (DEFAULT) — modern named cards with 2-word descriptors, the
#                          ChatGPT/Siri pattern ("Stephen — warm & direct"). No
#                          gender label. Shows 6 curated voices in a responsive grid.
#   gender               — explicit Male / Female / System default toggle. Renders
#                          a 2-column layout with cards stacked under each gender.
# Both modes share the same underlying voice catalog; only the picker's grouping
# and labeling differ. A redeploy is needed to switch modes (NEXT_PUBLIC_ inlining).
# NEXT_PUBLIC_VOICE_PICKER_MODE=descriptor

# ─── Google Cloud TTS (optional, v1.7) — permanent-free hedge ────────────────
# Adds a third TTS engine alongside browser + Polly. Google Cloud TTS Chirp 3 HD
# has a PERMANENT free tier (1M chars/mo) that never expires, hedging Polly's
# 12-month free-tier cliff. Voices: Aoede, Charon (curated) + Puck, Kore, Fenrir
# (extended). When unset, the picker still works — Google voices just don't appear
# and the engine option is hidden from settings. To enable, create an API key at
# https://console.cloud.google.com/apis/credentials with the Cloud Text-to-Speech
# API enabled, then set:
# GOOGLE_TTS_API_KEY=AIzaSy...

# ─── Telemetry / Observability (v1.8, server-side) ───────────────────────────
# Dual-sink structured event logging: Vercel Runtime Logs (always) +
# Upstash Redis sorted sets (best-effort, 7-day retention). Zero new vendors;
# requires existing UPSTASH_REDIS_REST_URL/_TOKEN to populate the dashboard.
# See TELEMETRY.md for the full reference.
#
#   TELEMETRY_ENABLED=false   — disables all event emission (default: on)
#   TELEMETRY_IP_SALT=...     — salt for SHA-256 IP hashing. Without this,
#                               IPs are stored as "anonymous" (fully private).
#                               Generate: openssl rand -base64 16
#   ADMIN_PASSWORD=...        — HTTP Basic Auth password for /admin/telemetry.
#                               When unset the page renders auth instructions.
#
# TELEMETRY_ENABLED=true
# TELEMETRY_IP_SALT=<openssl rand -base64 16>
# ADMIN_PASSWORD=<your-strong-password>

# ─── LLM SDK mode (v1.8, build-time) ──────────────────────────────────────────
# Which underlying SDK /api/chat uses to talk to Bedrock. Orthogonal to
# LLM_PROVIDER (that picks Bedrock vs direct Anthropic); this picks WHICH
# Bedrock client when LLM_PROVIDER=bedrock.
#   anthropic-bedrock (DEFAULT) — @anthropic-ai/bedrock-sdk, the v1.6+ shipping
#                                 SDK. Streaming + tool-use shape is what
#                                 streamWithFallback in src/lib/llm.ts is built
#                                 around.
#   aws-sdk-bedrock              — reserved for a v1.8.x follow-up that adds
#                                 OTel auto-instrumentation (the @aws-sdk/*
#                                 clients are auto-instrumented out of the box).
#                                 Today it falls through to the default with a
#                                 warning log — the streaming + tool-use rewrite
#                                 ships in the follow-up. Safe to set early.
# A redeploy is needed to switch SDKs (NEXT_PUBLIC_ is inlined at build time).
# NEXT_PUBLIC_LLM_SDK=anthropic-bedrock

# ─── Beast-mode feature flags (v1.9 + v2.0) — all default OFF ────────────────
# Set to "true" to enable. Require a redeploy (NEXT_PUBLIC_ = build-time inlining).
#
# v1.9 flags:
# NEXT_PUBLIC_ORB_POSTPROCESSING=true   # Bloom + Vignette + Noise + CA + cursor Fluid on 3D orb
#                                        # (high-tier devices only: ≥4 GB RAM + ≥4 cores)
# NEXT_PUBLIC_INK_TRANSITION=true        # WebGL2 ink-bleed shader on view switches
#                                        # (falls back to CSS crossfade if reduced-motion or
#                                        #  View Transitions API unavailable)
# NEXT_PUBLIC_SKILL_TREE=true            # SVG RPG Skill Tree at the bottom of the Play view
#
# v2.0 flags:
# NEXT_PUBLIC_404_ORB=true               # Distressed red/orange 3D orb above the 404 terminal
#                                        # (WebGLBoundary fallback: terminal-only when no WebGL)
# NEXT_PUBLIC_VISITOR_COUNTER=true       # "↑ N engineers visited" badge in the footer
#                                        # Requires UPSTASH_REDIS_REST_URL + _TOKEN
# NEXT_PUBLIC_DISCOVERY_BADGES=true      # "★ N/5 discovered" badge (bottom-right)
# NEXT_PUBLIC_VOICE_TEST_AUDIO=true      # Show "🔊 Test audio" button in talk mode (dev/QA only, default off)
#                                        # Backed by localStorage — no backend required
#                                        # 5 triggers: view-switch, chat-question,
#                                        # terminal-command, konami, dossier-open
#                                        # Escape hatch: ⌘K → "Unlock all discoveries"

# Add the active set to Vercel Project Settings → Environment Variables for production.

# ─── Hiring signal flags (build-time) ────────────────────────────────────────
# NEXT_PUBLIC_OPEN_TO_WORK — show a subtle "Open to work" banner below the nav.
#   Default: false. Set to "true" when actively job searching.
# NEXT_PUBLIC_OPEN_TO_WORK=true

# ─── Writing section feature flags (build-time) ──────────────────────────────
# Both control route, nav link, sitemap, and RSS for the writing sections.
# A redeploy is needed to toggle (NEXT_PUBLIC_ vars are inlined at build time).
#
# NEXT_PUBLIC_ARTICLES_ENABLED — default TRUE (omit or set to anything except "false")
# NEXT_PUBLIC_ARTICLES_ENABLED=false   # set to disable articles section
#
# NEXT_PUBLIC_NOTES_ENABLED — default FALSE (must explicitly opt in)
# NEXT_PUBLIC_NOTES_ENABLED=true       # set to enable notes section

# NEXT_PUBLIC_STATS_ENABLED=true   # Show /stats page in nav (default off)

# ─── Vercel Flags SDK — optional runtime flag evaluation ─────────────────────
# FLAG_DRIVER controls which evaluation path is used for NEXT_PUBLIC_DISCOVERY_BADGES:
#   local (DEFAULT)  — reads NEXT_PUBLIC_DISCOVERY_BADGES at build time (requires redeploy)
#   vercel           — evaluates via Vercel Flags SDK at request time (instant toggle,
#                       no redeploy). Requires FLAGS_SECRET to be set.
# FLAG_DRIVER=vercel
#
# FLAGS_SECRET — required when FLAG_DRIVER=vercel. Signs override cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# FLAGS_SECRET=<your-32-byte-base64url-secret>
